{
  "expo": {
    "name": "EasyBuy",
    "slug": "easybuy-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "easybuy-mobile",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.easybuy.mobile",
      "buildNumber": "13",
      "infoPlist": {
        "UIUserInterfaceStyle": "Automatic"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#d9006f"
      },
      "package": "com.easybuy.mobile",
      "versionCode": 13,
      "softwareKeyboardLayoutMode": "adjustResize"
    },
    "web": {
      "bundler": "metro"
    },
    "autolinking": {
      "exclude": [
        "@expo/dom-webview"
      ]
    },
    "plugins": [
      "expo-sqlite"
    ],
    "extra": {
      "eas": {
        "projectId": "342f2913-0fc4-4484-9cb8-04f93621d7fa"
      }
    },
    "owner": "rodneymarin"
  }
}
